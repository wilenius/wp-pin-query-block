{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "pin-query/featured-content",
	"version": "0.1.0",
	"title": "Featured Content",
	"category": "widgets",
	"icon": "thumbtack",
	"description": "Search and pin posts and events to display as featured content.",
	"attributes": {
		"pinnedPosts": {
			"type": "array",
			"default": []
		},
		"columns": {
			"type": "number",
			"default": 3
		}
	},
	"supports": {
		"html": false,
		"align": [ "wide", "full" ],
		"spacing": {
			"margin": true,
			"padding": true
		}
	},
	"textdomain": "wp-pin-query-block",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php"
}
